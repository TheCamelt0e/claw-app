# CLAW Mobile Environment Configuration
# Copy this file to .env.local for local development
# Set in EAS Secrets for production builds

# Backend API URL
# Production: https://claw-api-b5ts.onrender.com/api/v1
# Development (Android emulator): http://10.0.2.2:8000/api/v1
# Development (iOS simulator): http://localhost:8000/api/v1
EXPO_PUBLIC_API_URL=https://claw-api-b5ts.onrender.com/api/v1

# Optional: Analytics/Monitoring
# EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Optional: Feature Flags
# EXPO_PUBLIC_ENABLE_ANALYTICS=true
# EXPO_PUBLIC_ENABLE_CRASHLYTICS=true
